# Environment Configuration
NODE_ENV=development

# Server
PORT=3001

# Database
# PostgreSQL connection string
DATABASE_URL=postgresql://username:password@localhost:5432/healthai_db

# JWT Configuration
# Secret key for signing JWT tokens (minimum 32 characters)
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-required-here
JWT_EXPIRES_IN=3600s
JWT_ISSUER=healthai-api
JWT_AUDIENCE=healthai-frontend

# API Security
# API key for securing endpoints (minimum 32 characters)
API_KEY=your-api-key-minimum-32-characters-required-here

# Frontend Configuration
# Comma-separated list of allowed frontend origins
FRONTEND_ORIGIN=http://localhost:3000
# Frontend client ID for validation (minimum 8 characters)
FRONTEND_CLIENT_ID=frontend-client-id-min-8-chars

# Development Account (Development only - not used in production)
DEV_DEFAULT_USER_EMAIL=ngeMe123!dev-account
DEV_DEFAULT_USER_PASSWORD=ChangeMe123!dev-account